# ------------------------------
# Terraform core files
# ------------------------------

# Local .terraform directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# ------------------------------
# Terraform plan output
# ------------------------------
*.tfplan
*.plan

# ------------------------------
# Variable files (often sensitive)
# ------------------------------
*.tfvars
*.tfvars.json

# But allow example tfvars
!*.example.tfvars

# ------------------------------
# Lock file (optional - see note)
# ------------------------------
# Uncomment if you don't want to commit provider lock file
# .terraform.lock.hcl